UNITS LENGTH=A ENERGY=kcal/mol TIME=ps

# ATOMS DEFINITION
elp: GROUP ATOMS=7			# P attacked by the nucleophilic OH
oelp: GROUP ATOMS=8,9,10		# Oxygens linked to the electrophilic P
lvp: GROUP ATOMS=1			# Leaving P, i.e., the one that is not attacked by the nucleophile (H2PO3- fragmet, exclunsing the bridging oxygen)
olvp: GROUP ATOMS=2,3,4,5		# Oxygens linked to the leaving P

# WATER OXYGENS AND HYDROGENS DEFINITIONS
ow: GROUP ATOMS=12-309:3, 315-516:3
hw: GROUP ATOMS=13-517:3,14-518:3
nuc: GROUP ATOMS=312
mg1: GROUP ATOMS=6
mg2: GROUP ATOMS=11

# COODINATION SPHERES TO BUILD THE CVs
# Tracking the evolution of the coordination around the nucleophilic oxygen and the leaving group oxygens renders how the arrangement of the system change and provides a picture of the
# mechanism
cowh: COORDINATION GROUPA=nuc GROUPB=hw R_0=1.30 NLIST NL_CUTOFF=4.5 NL_STRIDE=100		# Nucleophile coordination
cobh: COORDINATION GROUPA=olvp GROUPB=hw R_0=1.20 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100	# Coordination sphere around the leaving group
coelp: COORDINATION GROUPA=oelp GROUPB=hw R_0=1.20 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100 	# Coordination of elecrophilic group
cmg1oelp: COORDINATION GROUPA=mg1 GROUPB=oelp R_0=1.2 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100
cmg2oelp: COORDINATION GROUPA=mg2 GROUPB=oelp R_0=1.2 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100
cmg1olvp: COORDINATION GROUPA=mg1 GROUPB=olvp R_0=1.2 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100
cmg2olvp: COORDINATION GROUPA=mg2 GROUPB=olvp R_0=1.5 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100
cMg1oh: COORDINATION GROUPA=mg1 GROUPB=ow R_0=1.3 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100
cMg2oh: COORDINATION GROUPA=mg2 GROUPB=ow R_0=1.3 NN=12 NLIST NL_CUTOFF=4.5 NL_STRIDE=100
cPPitot: COMBINE ARG=cobh,cowh,coelp COEFFICIENTS=1,1,1 PERIODIC=NO
# DISTANCES VARIABLES TO DEFINE THE CVs. 
#The simultaneous approach of the OH to the PP and the cleavage of the OP (same phosphorus) combined adds up to the CVs that tracks the reaction's development
dobp: DISTANCE ATOMS=2,7	# Distance between the bridging 'O' and the electron-attractor. The cleavage of the O-P bond is tracked by this distance
dowp: DISTANCE ATOMS=312,7 		# Distance between the nucleophile and the electron-attractor phosphorus. The nucleophilic attrack evolution is tracked throguh this distance
dD: COMBINE ARG=dowp,dobp COEFFICIENTS=1,-1 PERIODIC=NO  
dC: COMBINE ARG=cobh,cowh COEFFICIENTS=1,-1 PERIODIC=NO # CV relative to the coordination of the lv group, and the nucleophile

#Constraints on Magnesium coordination with PPi oxygen
cMg1PPi: COMBINE ARG=cmg1oelp,cmg1olvp COEFFICIENTS=1,1 PERIODIC=NO
cMg2PPi: COMBINE ARG=cmg2oelp,cmg2olvp COEFFICIENTS=1,1 PERIODIC=NO
cMg1tot: COMBINE ARG=cmg1oelp,cmg1olvp,cMg1oh COEFFICIENTS=1,1,1 PERIODIC=NO
cMg2tot: COMBINE ARG=cmg2oelp,cmg2olvp,cMg2oh COEFFICIENTS=1,1,1 PERIODIC=NO

#UPPER and LOWER WALLS OF CVs
uw_1: UPPER_WALL ARG=cowh,cobh,coelp,cPPitot AT=2.1,1.1,1.1,2.1 KAPPA=500.0,500.0,500.0,500.0 EXP=2,2,2,2 EPS=1,1,1,1
uw_Mg: UPPER_WALL ARG=cMg1PPi,cMg2PPi,cMg1tot,cMg2tot AT=2.1,2.1,6.1,6.1 KAPPA=500.0,500.0,1000.0,1000.0 EXP=2,2,2,2 EPS=1,1,1,1
lw_1: LOWER_WALL ARG=cowh,cobh,coelp AT=0.8,1.5,1.5 KAPPA=500.0,500.00,500.0 EXP=2,2,2 EPS=1,1,1,1
lw_Mg: LOWER_WALL ARG=cMg1PPi,cMg2PPi AT=0.8,0.8 KAPPA=500.0,500.0 EXP=2,2 EPS=1,1

#Maybe Mg-water coordination will need a lower constraint

#Distances to mantain Mg attached to the PPi along the exploration
dMgMg: DISTANCE ATOMS=6,11  #Mg-Mg distance
dP1Mg2: DISTANCE ATOMS=1,11  #P1-Mg2 distance
dP2Mg2: DISTANCE ATOMS=7,11  #P2-Mg2 distance
dP1Mg1: DISTANCE ATOMS=1,6  #P1-Mg1 distance
dP2Mg1: DISTANCE ATOMS=7,6  #P2-Mg1 distance
lw_Mgs: LOWER_WALLS ARG=dMgMg,dP1Mg2,dP2Mg2,dP1Mg1,dP2Mg1 AT=3.0 KAPPA=100.0 EXP=2 EPS=1 #To track here and eventually add constraints

# THIS IS THE OPES EXPLORATION OF THE TS (NOT REQUIRED HERE)
#dD_sum: COMBINE ARG=dobp,dowp COEFFICIENTS=1,1 PERIODIC=NO #It only tracks the sum of the distances
#Prevents to lose the TS structure and set the O-P-O combined parameter within -0.05 and 0.05
#uwall_1: UPPER_WALLS ARG=dD AT=0.05 KAPPA=1000.0 EXP=2 EPS=1
#lwall_1: LOWER_WALLS ARG=dD AT=-0.05 KAPPA=1000.0 EXP=2 EPS=1

# COORDINATION AND DISTANCES ON PPi OXYGENS (do I have to consider it in this case? I mean, the Mg are going to be bound in any moment to the oxygens, so it is relevant to control water coord. in a SMD?)
# Prevents the oxygens of the nucleophile, of the leaving group and the electrophilic group to exceed the excpected coordination. Moreover, prevents the nucleophile to float away the
# electrophilic center, and the leaving group to float away from the electrophilic center 
#uw_2: UPPER_WALLS ARG=cowh,cobh,coelp,dobp,dowp AT=2.2,1.2,1.2,3.5,3.5 KAPPA=500.0,500.0,500.0,500.0,500.0 EXP=2,2,2,2,2 EPS=1,1,1,1,1		#The original constraint
uw_2: UPPER_WALLS ARG=cobh,coelp,dobp,dowp AT=1.2,1.2 KAPPA=500.0,500.0 EXP=2,2 EPS=1,1		#Still I reckon there is no point in setting these conditions
#sum_nuc_lv: COMBINE ARG=cowh,cobh COEFFICIENTS=1,1 PERIODIC=NO		#Coordination of the nucleophile OH and of the leaving group
#sum_htot: COMBINE ARG=cowh,cobh,coelp COEFFICIENTS=1,1,1 PERIODIC=NO   	#Coordination of the total system (nuc+lv group+electrophile)
#sum_pyro: COMBINE ARG=coelp,cobh COEFFICIENTS=1,1 PERIODIC=NO
#uw_sum: UPPER_WALLS ARG=sum_nuc_lv,sum_htot,sum_pyro AT=2.2,2.2,1.2 KAPPA=500.0,500.0,500.0 EXP=2,2,2 EPS=1,1,1 	#Set the maximum values of the combined corrdination of nuc+lv and the total one
#uw_sum: UPPER_WALLS ARG=sum_nuc_lv,sum_htot,sum_pyro AT=2.2,2.2,1.2 KAPPA=500.0,500.0,500.0 EXP=2,2,2 EPS=1,1,1 	#Set the maximum values of the combined corrdination of nuc+lv and the total one
#lw_2: LOWER_WALLS ARG=cowh,cobh,coelp AT=0.8,1.8,0.8 KAPPA=500.0,500.0,500.0 EXP=2,2,2 EPS=1,1,1			#Prevents the nucleophile OH and the lv group to their hydrogens

#ANGLE RESTRAINT (THERE IS NO NUCLEOPHILIC ATTACK HERE)
#To avoid the formation of the metaphosphate the attack of the oxygen must be directed toward P. The angle can't be lower than 2.618 rad (more or leass 150Â)
#aobpow: ANGLE ATOMS=228,3,6 # Mantains a fixed angle between the nucleophilic O and the to avoid the formation of metaphosphate
#lwall_angle: LOWER_WALLS ARG=aobpow AT=2.618 KAPPA=500.0 EXP=2 EPS=1 


#LWs to prevent the formation of pyrophosphate with the remaining leaving oxygens (AGAIN, no attack here, no need to restrain distance nor angles)
#dP2O1P1: DISTANCE ATOMS=9,3 # Distance of electron-attractor phosporus from the lv oxygen
#dP2O2P1: DISTANCE ATOMS=8,3 # Distance of the electron-attractor phosporus from the lv oxygen
#dP2O3P1: DISTANCE ATOMS=10,3 # Distance of the electron-attractor phosporus from the lv oxygen
#lwall_3: LOWER_WALLS ARG=dP2O1P1,dP2O2P1,dP2O3P1 AT=3.2,3.2,3.2 KAPPA=250.0,250.0,250.0 EXP=2,2,2 EPS=1,1,1

#Upper walls to prevent the hydroxyde ion to detach from Mg and to gain a proton (Mgs are no longer constrained to the edges of the box)

#Upper wall on coordination of the attacked phosphorus with any oxygen of the rest of water molecules
#cowbulkp: COORDINATION GROUPA=elp GROUPB=ow R_0=1.9 NN=8 NLIST NL_CUTOFF=5.1 NL_STRIDE=100
#uwall_bulkp: UPPER_WALLS ARG=cowbulkp AT=0.08 KAPPA=5000.0 EXP=2 EPS=1 		# There can't be any coordination of the leaving electrophilic phosphorus by any other water molecules 
										#except the nucleophilic one

# Track H3O+ or HO- in the solvent
#COORDINATIONNUMBER LOWMEM SPECIESA=ow SPECIESB=hw SWITCH={RATIONAL R_0=1.30 NN=6 MM=12 D_MAX=5.0} HIGHEST LOWEST LABEL=CV_c_OwHw_cn
COORDINATIONNUMBER LOWMEM SPECIESA=ow SPECIESB=hw SWITCH={RATIONAL R_0=1.30 NN=50 MM=100 D_MAX=5.0} HIGHEST LOWEST LABEL=CV_Hc_OwHw_cn


steered_md: MOVINGRESTRAINT ... # dD is brought from -2.0 to 2.0 in 400k steps mantaining the force costants unaltered
   ARG=dcMg1,dcMg2
   STEP0=0 AT0=3.0,-3.0 KAPPA0=200 # At the beginning the the Magnesiums are bound three to each group
   STEP1=400000 AT1=-3.0,3.0 KAPPA1=200 # After 400k steps, the nucleophile is close to phosphorus (bond), while the other phosporus left
...
# OPES setup: to check the barrier with Adrian
#opes: OPES_METAD ARG=cowh,cobh,coelp,dD_sum PACE=100 SIGMA=0.07,0.07,0.07,0.07 TEMP=298.15 BARRIER=50

PRINT STRIDE=500 ARG=cowh,cobh,coelp,dobp,dowp,sum_nuc_lv,sum_pyro,sum_htot,dC,dD,dD_sum FILE=COLVAR
PRINT STRIDE=500 ARG=aobpow,cowbulkp FILE=additional_feat.log
PRINT STRIDE=500 ARG=dD,opes.* FILE=TS_dD.dat

#FLUSH STRIDE=_R_PRINT_FREQ_

ENDPLUMED
