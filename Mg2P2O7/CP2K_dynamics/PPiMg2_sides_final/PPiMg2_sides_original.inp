@SET SYSNAME PPiMg2_sides

&GLOBAL
  PROJECT     ${SYSNAME}
  PRINT_LEVEL LOW
  RUN_TYPE    MD
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
    BASIS_SET_FILE_NAME    GTH_BASIS_SETS
    POTENTIAL_FILE_NAME    GTH_POTENTIALS
    CHARGE 0
    &MGRID
      CUTOFF    400
      REL_CUTOFF 50
    &END MGRID
    &QS
      EPS_DEFAULT   1.0E-10
      EPS_FILTER_MATRIX 0
      EPS_PGF_ORB 1.0E-14
    &END QS
    &SCF
      SCF_GUESS RESTART
      EPS_SCF   1.0E-6
      MAX_SCF   20
      ! store the wfn during MD for labelling
      &PRINT
        &RESTART
          &EACH
            MD 100
          &END EACH
          ADD_LAST NUMERIC
        &END
      &END
      &OT
        MINIMIZER DIIS
        PRECONDITIONER FULL_ALL
      &END OT
      &OUTER_SCF
        EPS_SCF  1.0E-6
        MAX_SCF  20
      &END OUTER_SCF
    &END SCF
    &XC
      &XC_FUNCTIONAL
	&PBE
	  PARAMETRIZATION REVPBE
	&END PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3
          D3_EXCLUDE_KIND_PAIR 1 1
          D3_EXCLUDE_KIND_PAIR 1 2
          D3_EXCLUDE_KIND_PAIR 1 3
          D3_EXCLUDE_KIND_PAIR 1 4
          R_CUTOFF 10.0
          REFERENCE_FUNCTIONAL revPBE
          PARAMETER_FILE_NAME  dftd3.dat
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC

  &END DFT

  &SUBSYS
    &CELL
    A 17.20   0.     0.
    B  0.    17.20   0.
    C  0.     0.    17.20
    &END CELL
    &TOPOLOGY
      COORD_FILE_FORMAT XYZ
      COORD_FILE_NAME PPiMg2_sides.xyz
    &END TOPOLOGY
    &KIND H
      BASIS_SET          DZVP-GTH-q1
      POTENTIAL          GTH-PBE-q1
    &END KIND
    &KIND O
      BASIS_SET          DZVP-GTH-q6
      POTENTIAL          GTH-PBE-q6
    &END KIND
    &KIND P
      BASIS_SET          DZVP-GTH-q5
      POTENTIAL          GTH-PBE-q5
    &END KIND
    &KIND Mg
      BASIS_SET          DZVP-GTH-q10
      POTENTIAL          GTH-PBE-q10
    &END KIND
  &END SUBSYS
&END FORCE_EVAL

&MOTION
 &MD
  ENSEMBLE        NVT
  STEPS           20000
  TIMESTEP [fs]   0.5
  TEMPERATURE [K] 298.0
  &THERMOSTAT
   TYPE NOSE
   REGION GLOBAL
   &NOSE
     LENGTH 3
     YOSHIDA 3
     TIMECON 100.0
     MTS 2
   &END NOSE
  &END THERMOSTAT
  
  &PRINT
   &ENERGY
    FILENAME =${SYSNAME}-Energy.en
    LOG_PRINT_KEY
    &EACH
     MD 100
    &END EACH
    ADD_LAST NUMERIC
   &END ENERGY
   &PROGRAM_RUN_INFO
    FILENAME =${SYSNAME}-Motion.log
    LOG_PRINT_KEY
    &EACH
     MD 100
    &END EACH
    ADD_LAST NUMERIC
   &END PROGRAM_RUN_INFO
  &END PRINT
 &END MD
 &PRINT
  &TRAJECTORY
   FORMAT XYZ
   UNIT angstrom
   FILENAME =${SYSNAME}-Trajectory.xyz
   LOG_PRINT_KEY
   &EACH
    MD 200
   &END EACH
   ADD_LAST NUMERIC
  &END TRAJECTORY
  &RESTART
   FILENAME =${SYSNAME}-MD.restart
   LOG_PRINT_KEY
   &EACH
    MD 200
   &END EACH
   ADD_LAST NUMERIC
  &END RESTART
 &END PRINT
&END MOTION

